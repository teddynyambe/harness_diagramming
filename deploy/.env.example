# Copy to ".env" and adjust.  ->  cp .env.example .env

# Port the app is served on
HOST_PORT=8270

# Where configs + backups are persisted ON THE SERVER.
# Use an absolute path in production, e.g. /srv/harness-bench/data
DATA_DIR=./data

# Authentication: leave true until real auth is wired in backend/app/auth.py
AUTH_DISABLED=true

# How many timestamped backups to keep per config
MAX_BACKUPS=50
